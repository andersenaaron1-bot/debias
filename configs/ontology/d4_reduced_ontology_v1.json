{
  "name": "d4_reduced_ontology_v1",
  "description": "Reduced tracing ontology selected from D1 operational atoms, D2 bundle structure, D3 ecological relevance on Laurito, and M2-vs-M3 contrast.",
  "selection_rule": {
    "purpose": "Keep low-level, mechanistically plausible cue atoms that either show ecological relevance in D3 or move materially between M2 and M3.",
    "criteria": [
      "Atom is operationalized in D1/D2.",
      "Atom is plausibly content-light and local enough to be traced in SAE feature space.",
      "Atom or enclosing bundle shows non-null D3 evidence on M2 or M3, or atom shows meaningful M2-vs-M3 contrast.",
      "Prefer atom-level targets over bridge/register variables for first-pass tracing."
    ],
    "contrast_threshold_guideline": {
      "bundle_abs_delta_z": 0.04,
      "atom_abs_delta_z": 0.06
    }
  },
  "trace_bundles": [
    {
      "bundle_id": "formal_information_packaging",
      "status": "primary",
      "motivation": "Captures the academic-formality signal in lower-level lexical and constructional atoms instead of a single coarse register label.",
