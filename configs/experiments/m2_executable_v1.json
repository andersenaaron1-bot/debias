    "cue_batch_size": 16,
    "lambda_max": 0.2,
    "lambda_ramp_frac": 0.1,
    "lambda_cue": 1.0,
    "cue_grl_scale": 1.0,
    "cue_families": [
      "academic_formality",
      "safety_corporate_tone",
      "promotional_sales_tone",
